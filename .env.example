APP_NAME=SEMS

DB_URL=jdbc:mysql://localhost:3306/sems_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MINUTES=30

OTP_EXPIRATION_MINUTES=5
OTP_LENGTH=6

LOCKOUT_MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
LOGIN_RATE_LIMIT_MAX_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

SEED_DATA_ENABLED=true
SEED_DEFAULT_PASSWORD=Password@123

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=SEMS <your_email@gmail.com>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_SSL_ENABLE=true
